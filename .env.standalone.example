# ============================================
# AI 创作室 - 独立前端部署环境变量
# 
# 使用方法：
# 1. 复制此文件为 .env
# 2. 从 Coze 环境变量中获取以下值并填写
# 3. 运行: docker-compose -f docker-compose.standalone.yml up -d
# ============================================

# ============================================
# 数据库配置（从 Coze 环境获取）
# ============================================

# Supabase URL
# 在 Coze 环境: env | grep COZE_SUPABASE_URL
COZE_SUPABASE_URL=https://br-glad-tody-dccd036b.supabase2.aidap-global.cn-beijing.volces.com

# Supabase Anon Key
# 在 Coze 环境: env | grep COZE_SUPABASE_ANON_KEY
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# 对象存储配置（从 Coze 环境获取）
# ============================================

# 对象存储端点
# 在 Coze 环境: env | grep COZE_BUCKET_ENDPOINT_URL
COZE_BUCKET_ENDPOINT_URL=https://integration.coze.cn/coze-coding-s3proxy/v1

# 存储桶名称
# 在 Coze 环境: env | grep COZE_BUCKET_NAME
COZE_BUCKET_NAME=your-bucket-name-here
