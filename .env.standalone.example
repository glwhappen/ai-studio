# ============================================
# AI 创作室 - 独立部署环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.standalone.example .env

# ============================================
# 数据库配置（必需）
# ============================================

# 方式1：使用 Supabase Cloud（推荐）
# 从 Supabase 项目设置中获取
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key

# 方式2：使用自建 PostgreSQL
# COZE_SUPABASE_URL=http://postgres:5432/postgres
# COZE_SUPABASE_ANON_KEY=your-postgres-password

# ============================================
# 对象存储配置（必需）
# ============================================
# 独立部署必须配置自己的 S3 兼容存储
# 支持：AWS S3、MinIO、阿里云 OSS、腾讯云 COS 等

# S3 端点 URL
# - AWS S3: https://s3.amazonaws.com
# - 阿里云 OSS: https://oss-cn-hangzhou.aliyuncs.com
# - 腾讯云 COS: https://cos.ap-guangzhou.myqcloud.com
# - MinIO (本地): http://minio:9000
S3_ENDPOINT_URL=https://s3.amazonaws.com

# 存储桶名称
S3_BUCKET_NAME=your-bucket-name

# 访问凭据
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# 区域（可选，默认 us-east-1）
S3_REGION=us-east-1

# ============================================
# 可选：自建 MinIO 配置
# ============================================
# 如果使用 docker-compose.standalone.yml 中的 minio 服务
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# 可选：自建 PostgreSQL 配置
# ============================================
# POSTGRES_PASSWORD=your-secure-password
