# ============================================
# AI 创作室 - 独立部署环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值
# cp .env.standalone.example .env

# ============================================
# 方式一：连接 Coze 环境（推荐）
# ============================================
# 从 Coze 环境的 /api/env?full=1 获取以下配置

# 数据库配置
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key

# 对象存储配置
COZE_BUCKET_ENDPOINT_URL=https://integration.coze.cn/coze-coding-s3proxy/v1
COZE_BUCKET_NAME=your-bucket-name

# ⚠️ 关键：此变量是使用 Coze 托管存储的必要条件
# 必须从 Coze 环境的 /api/env?full=1 获取
COZE_WORKLOAD_IDENTITY_API_KEY=your-workload-identity-api-key

# ============================================
# 方式二：自建服务（完全离线部署）
# ============================================

# 数据库配置（PostgreSQL 直连）
# COZE_SUPABASE_URL=postgresql://postgres:password@postgres:5432/postgres
# COZE_SUPABASE_ANON_KEY=any-value

# 对象存储配置（S3 兼容存储）
# 支持：AWS S3、MinIO、阿里云 OSS、腾讯云 COS 等
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_BUCKET_NAME=your-bucket-name
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=us-east-1

# ============================================
# 可选：自建 MinIO 配置
# ============================================
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin

# ============================================
# 可选：自建 PostgreSQL 配置
# ============================================
# POSTGRES_PASSWORD=your-secure-password
